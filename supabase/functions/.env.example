# supabase/functions/.env  — LOCAL DEV ONLY
# This file is .gitignored and must never be committed.
# For production, set STRIPE_SECRET_KEY in the Supabase dashboard:
#   supabase.com → your project → Edge Functions → Secrets

# Paste your Stripe secret key here for local testing only.
# Use a Stripe secret key from Stripe Dashboard. Do not commit real keys.
STRIPE_SECRET_KEY=<YOUR_STRIPE_SECRET_KEY>
